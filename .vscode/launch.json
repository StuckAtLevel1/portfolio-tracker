{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Electron: Debug Main",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start", "--", "--inspect-brk"],
      "cwd": "${workspaceFolder}",
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/.vite/build/**/*.js"
      ],
      "console": "integratedTerminal",
      "autoAttachChildProcesses": true
    },
    {
      "name": "Electron: Forge Start (no debug)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
